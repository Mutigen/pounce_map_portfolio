# Google Maps JavaScript API Key
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Google Maps Map ID (required for AdvancedMarkerElement)
VITE_GOOGLE_MAPS_MAP_ID=YOUR_MAP_ID_HERE

# JSON Feed URL (from Make.com Scenario B)
VITE_JSON_FEED_URL=https://hook.us1.make.com/xxxxx/feeds/latest.json

# Make.com Webhook URL (for LOG NOTE submissions - Scenario C)
VITE_MAKE_WEBHOOK_URL=https://hook.us1.make.com/xxxxxxxxxxxxx

# Airtable Form URL (fallback, optional)
VITE_AIRTABLE_FORM_URL=https://airtable.com/shrXXXXXXXXXX

# Debug mode (set to false in production)
VITE_DEBUG=true
